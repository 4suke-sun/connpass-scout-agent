{
  "name": "ai-auto-dev-framework",
  "version": "0.1.0",
  "description": "Auto-mode safe development framework for Claude Code",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "audit": "npm audit --audit-level=high",
    "licenses": "license-checker --production --json --out THIRD_PARTY_LICENSES.json && license-checker --production --failOn 'GPL-2.0;GPL-3.0;AGPL-1.0;AGPL-3.0'",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "lefthook": "^2.1.8",
    "license-checker": "^25.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
